<Window x:Class="FunkctionGraphDrawer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FunkctionGraphDrawer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="FunctionInput" Width="200" Margin="5" Text="Enter function (For example : x*y + 2)"
                              GotFocus="FunctionInput_GotFocus" LostFocus="FunctionInput_LostFocus"/>
            <TextBox x:Name="XInput" Width="200" Margin="5" Text="Enter X" />
            <TextBox x:Name="YInput" Width="200" Margin="5" Text="Enter Y" />
            <Button Content="Calculate" Width="200" Margin="5" Click="CalculateButton_Click"/>
            <Label x:Name="ResultLabel" Content="Result: " Width="200" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
